<Project>
    <PropertyGroup>
        <Sts2Path>/path/to/Slay the Spire 2</Sts2Path>

        <!--
          WSL building against a Windows Steam install usually needs the
          Windows data directory explicitly:

          <Sts2Path>/mnt/DRIVE/SteamLibrary/steamapps/common/Slay the Spire 2</Sts2Path>
          <Sts2DataDir>$(Sts2Path)/data_sts2_windows_x86_64</Sts2DataDir>
        -->
    </PropertyGroup>
</Project>
